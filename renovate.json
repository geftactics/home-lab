{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "kubernetes": {
    "fileMatch": ["\\.yaml$"]
  },
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "ignoreTests": true,
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],

  "pruneBranchAfterAutomerge": true
}
